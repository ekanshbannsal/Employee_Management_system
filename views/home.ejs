<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>

    <style>
        body{
            font-family: Arial, sans-serif;
            background: #f4f6f9;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
        }

        h1{
            color: #2c3e50;
            margin-bottom: 40px;
        }

        a{
            text-decoration: none;
            background-color: #3498db;
            color: white;
            padding: 12px 25px;
            border-radius: 8px;
            font-size: 18px;
            transition: 0.3s;
            box-shadow: 0 4px 8px rgba(0,0,0,0.15);
        }

        a:hover{
            background-color: #2980b9;
            transform: translateY(-2px);
        }
    </style>

</head>
<body>
    <h1>Lorem ipsum dolor sit.</h1>

    <a href="http://localhost:3000/viewdata">ALL employee data</a>
    <br><br>
    <a href="http://localhost:3000/insertdata">add employee  data</a>

</body>
</html>